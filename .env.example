# ── Frontend (Vite) — these values ARE bundled into the browser. ──────────────
# Only ever put PUBLIC, non-sensitive values under VITE_*.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-anon-key>
VITE_SINPE_PHONE=XXXX-XXXX
VITE_SINPE_NAME=Your Name
# URL of the Express API — empty string means "same origin" (works with Vite proxy in dev)
VITE_API_URL=

# ── Backend (Node.js/Express) — NEVER prefix these with VITE_. ───────────────
SUPABASE_URL=https://<project-ref>.supabase.co
# Get from: Supabase Dashboard → Project Settings → API → service_role key
# WARNING: This key bypasses Row Level Security. Keep it server-side only.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<your-service-role-key>
SUPABASE_STORAGE_BUCKET=stl-files
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# SINPE (also used by server if needed)
SINPE_PHONE=XXXX-XXXX
SINPE_NAME=Your Name

# ── Admin credentials ─────────────────────────────────────────────────────────
# Generate JWT secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=<64-byte-hex-string>
# Store a bcrypt hash here, not the plaintext password.
# Generate: node -e "require('bcryptjs').hash('your-password', 12).then(console.log)"
ADMIN_USERNAME=<admin-username>
ADMIN_PASSWORD=<bcrypt-hash>

# ── Contact form email (Gmail SMTP) ───────────────────────────────────────────
# Google account that sends the emails (must have an App Password configured).
# Generate App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=your-gmail-account@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Destination address for contact form submissions
CONTACT_EMAIL=info@inity3d.com
