# ── Frontend (Vite) — these values ARE bundled into the browser. ──────────────
# Only ever put PUBLIC, non-sensitive values under VITE_*.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-anon-key>
VITE_SINPE_PHONE=XXXX-XXXX
VITE_SINPE_NAME=Your Name
# URL of the Express API — empty string means "same origin" (works with Vite proxy in dev)
VITE_API_URL=
# "supabase" → printers/materials/settings fetched from Supabase (multi-device).
# Absent or any other value → localStorage fallback.
VITE_CONFIG_SOURCE=supabase

# ── Backend (Node.js/Express) — NEVER prefix these with VITE_. ───────────────
SUPABASE_URL=https://<project-ref>.supabase.co
# Get from: Supabase Dashboard → Project Settings → API → service_role key
# WARNING: This key bypasses Row Level Security. Keep it server-side only.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<your-service-role-key>
SUPABASE_STORAGE_BUCKET=stl-files
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# SINPE (also used by server if needed)
SINPE_PHONE=XXXX-XXXX
SINPE_NAME=Your Name

# ── Admin credentials ─────────────────────────────────────────────────────────
# Generate JWT secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=<64-byte-hex-string>
# Store a bcrypt hash here, not the plaintext password.
# Generate: node -e "require('bcryptjs').hash('your-password', 12).then(console.log)"
ADMIN_USERNAME=<admin-username>
ADMIN_PASSWORD=<bcrypt-hash>

# ── Contact form email (Resend) ───────────────────────────────────────────────
# Get API key from: https://resend.com/api-keys
# The sending domain (inity3d.com) must be verified in the Resend dashboard.
RESEND_API_KEY=re_<your-resend-api-key>
# Destination address for contact form submissions
CONTACT_EMAIL=info@inity3d.com

# ── Gmail SMTP (no longer used by contact.js — kept for reference) ────────────
# GMAIL_USER=your-gmail-account@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Cloudflare R2 Storage (backend only — never VITE_) ───────────────────────
# "r2" → new file uploads go to R2 (larger file support, no egress cost).
# Absent or "supabase" → uploads go to Supabase Storage (legacy behavior).
# Rollback: change back to "supabase" in Railway; existing R2 files stay accessible
# because admin download routing is path-based (r2/ prefix), not env-var-based.
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=<bucket-name>
# Endpoint format: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
